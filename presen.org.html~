<div class="org-src-container">
<pre class="src src-python"><span style="color: #a020f0;">import</span> numpy <span style="color: #a020f0;">as</span> np
<span style="color: #a020f0;">def</span> <span style="color: #0000ff;">unit</span>(i):
    <span style="color: #a0522d;">x</span> = np.zeros([i,i])
    <span style="color: #a020f0;">for</span> i <span style="color: #a020f0;">in</span> <span style="color: #483d8b;">range</span>(i):
        x[i][i] = 1
    <span style="color: #a020f0;">return</span> x
</pre>
